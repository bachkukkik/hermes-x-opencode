# Required: API key for your LLM provider
OPENAI_API_KEY=sk-your-key-here

# Required: OpenAI-compatible base URL for your LLM provider
# Examples:
#   https://api.openai.com/v1          (OpenAI direct)
#   https://openrouter.ai/api/v1       (OpenRouter)
#   https://your-litellm-proxy.com/v1  (LiteLLM proxy)
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Required: Default model (must be available at your provider endpoint)
# All other chat models are auto-discovered from the /models endpoint at startup.
OPENAI_DEFAULT_MODEL=openai/gpt-4o

# Optional: Small model for lightweight OpenCode tasks (title generation, etc.)
# Falls back to OPENAI_DEFAULT_MODEL if not set.
# OPENAI_SMALL_MODEL=openai/gpt-4o-mini

# Optional: Per-app model overrides.
# When commented out, each app follows OPENAI_DEFAULT_MODEL (and OPENAI_SMALL_MODEL
# where applicable). Uncomment and set to use a different model for a specific app.
# HERMES_DEFAULT_MODEL=openai/my-hermes-model
# OPENCODE_DEFAULT_MODEL=openai/my-opencode-model
# OPENCODE_SMALL_MODEL=openai/my-opencode-small-model

# Required: OpenCode Zen API key (sign up at https://opencode.ai/auth, add billing, copy key)
# Even "free" models (deepseek-v4-flash-free, etc.) require a valid API key for authentication.
# Without a valid key, opencode/ prefixed models return 401 Invalid API key.
# If you only use models from your own LLM provider (via OPENAI_BASE_URL), you can leave this empty.
OPENCODE_API_KEY=

# Optional: Skip the WebUI onboarding wizard (useful for pre-configured deployments)
HERMES_WEBUI_SKIP_ONBOARDING=true

# Optional: Password-protect the WebUI (leave empty for no auth)
HERMES_WEBUI_PASSWORD=

# Optional: Host port for the WebUI (default: 8787)
HERMES_WEBUI_PORT=8787

# Optional: Host port for Hermes Agent API (default: 8642)
HERMES_API_PORT=8642

# Optional: API key for Hermes Agent OpenAI-compatible endpoint.
# Leave empty to auto-generate a random key. Set to a secret string to use a fixed key.
HERMES_API_KEY=

# Optional: Host port for OpenCode serve (default: 4096)
OPENCODE_SERVE_PORT=4096

# Optional: Host UID/GID for file permissions (default: 1000)
HOST_UID=1000
HOST_GID=1000

# Optional: Workspace directory mount (default: ./volumes_hermes_opencode/data/workspace)
# HERMES_WORKSPACE=./volumes_hermes_opencode/data/workspace

# Optional: Skip skill installation at container start (set to 1 for faster restarts)
# SKIP_SKILL_INSTALL=

# Optional: OpenCode agent security mode (default: strict)
#   strict   = hardened permissions — deny interpreters (python3 -c, node -e, etc),
#              env dump (printenv, env, echo $VAR), .env file access, destructive git
#              (reset --hard, push --force), and shell wrappers (bash -c, sh -c)
#   standard = balanced permissions  — deny env dump, .env file access, and destructive git;
#              allow interpreter one-liners and shell wrappers
#   yolo     = unrestricted — all tools allowed, no permission restrictions
# Default is 'strict' (matches docker-compose.yml fallback).
# Set to 'standard' to allow interpreter one-liners, or 'yolo' for unrestricted access.
OPENCODE_SECURITY_MODE=strict

# Optional: Hermes YOLO mode (default: 1 = on).
# When enabled (1), sets approvals.mode: off in the generated config.yaml, skipping
# dangerous-command approval prompts entirely — equivalent to running `hermes --yolo`.
# Set to 0 to restore manual approval prompts before running potentially dangerous commands.
HERMES_YOLO_MODE=1

# Optional: Default max tool-calling turns for delegate_task subagents (default: 50).
# Maps to delegation.max_iterations in the generated config.yaml. The Hermes built-in
# default is 50. Increase for complex delegated tasks, decrease to cap subagent runtime.
HERMES_DELEGATION_MAX_ITERATIONS=50

# Optional: Start `opencode serve` (headless server for `opencode attach`) on :4096.
# Disabled by default. Enable only when an LLM provider is configured, because
# serve exits immediately otherwise and tears the container down via wait -n.
OPENCODE_SERVE_ENABLED=true

# Optional: Seconds to wait for opencode serve to bind :4096 at boot (default: 30).
# A timeout is non-fatal — the container continues starting and `wait -n` will still
# observe a later serve crash if one occurs. Increase on slow disks / cold model loads.
OPENCODE_SERVE_BOOT_TIMEOUT=30

# Optional: Enable browser human-in-the-loop (Chromium + VNC inside container).
# When true, starts Xvfb, x11vnc, websockify+noVNC, and Chromium with CDP on :9222.
# Access the interactive browser via http://<host>:6901/vnc.html.
BROWSER_HUMAN_LOOP_ENABLED=false

# Optional: VNC password for browser human-in-the-loop (default: hermes).
# IMPORTANT: Change this from the default before exposing port 6901 beyond localhost.
BROWSER_VNC_PASSWORD=

# Optional: Wiki directory path INSIDE the container (default: /home/hermeswebui/.hermes/wiki).
# This is where the containerised agent stores its wiki files. The default matches
# docker-compose.yml, so you only need to override this if you want a custom location.
WIKI_PATH=/home/hermeswebui/.hermes/wiki

# Optional: Host path for the wiki volume mount.
# To share a personal wiki with the container agent, uncomment the wiki volume line
# in docker-compose.yml and set this to your host wiki path, e.g.:
#   HERMES_WIKI_VOLUME=/home/username/.hermes/wiki
# When set, the host directory is bind-mounted into the container at WIKI_PATH.
# HERMES_WIKI_VOLUME=/home/username/.hermes/wiki